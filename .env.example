# Database Configuration
DATABASE_URL=postgresql://postgres@localhost:5432/verifyus

# Proof Encryption Key (32 bytes hex - generate with: openssl rand -hex 32)
PROOF_ENCRYPTION_KEY=your-64-character-hex-key-here-replace-this-with-actual-key

# API Configuration
NODE_ENV=development
PORT=3001
API_PORT=3001
API_BASE_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# zkPass Configuration
ZKPASS_APP_ID=your-zkpass-app-id
ZKPASS_SCHEMA_ID=your-schema-id

# ATS Integration
GREENHOUSE_API_KEY=
GREENHOUSE_WEBHOOK_SECRET=
LEVER_API_KEY=
LEVER_WEBHOOK_SECRET=

# Rate Limiting (Redis)
REDIS_URL=

# Session/Auth
SESSION_SECRET=your-session-secret-here
JWT_SECRET=your-jwt-secret-here

# Email (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@verifyus.com

# Blockchain (optional - for on-chain proof registry)
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=polygon
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info
