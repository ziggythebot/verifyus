{
  "schema_metadata": {
    "name": "US Work Authorization Verification",
    "version": "1.0.0",
    "description": "Verify US work authorization without revealing identity details",
    "category": "Identity/KYC",
    "issuer": "VerifyUS by Enticeable",
    "valid_duration_days": 90,
    "created_at": "2026-03-12T00:00:00Z"
  },
  "assertion_groups": [
    {
      "name": "US Passport Verification",
      "method": "us_passport",
      "data_source": {
        "type": "zkTLS",
        "endpoint": "https://passportverify.uscis.gov/api/validate",
        "description": "USCIS Electronic Passport Database"
      },
      "assertions": [
        {
          "field": "document_type",
          "operator": "equals",
          "value": "US_PASSPORT",
          "required": true
        },
        {
          "field": "citizenship",
          "operator": "equals",
          "value": "USA",
          "required": true
        },
        {
          "field": "document_status",
          "operator": "equals",
          "value": "VALID",
          "required": true
        },
        {
          "field": "expiration_date",
          "operator": "greater_than",
          "value": "current_date",
          "required": true
        },
        {
          "field": "holder_age",
          "operator": "greater_than_or_equal",
          "value": 16,
          "required": true
        }
      ],
      "selective_disclosure": {
        "revealed_fields": [],
        "hidden_fields": [
          "full_name",
          "passport_number",
          "date_of_birth",
          "place_of_birth",
          "photograph"
        ]
      }
    },
    {
      "name": "State ID / Driver's License Verification",
      "method": "state_id",
      "data_source": {
        "type": "zkTLS",
        "endpoint": "https://dmv.{state}.gov/api/verify",
        "description": "State DMV verification portals (state-specific endpoints)"
      },
      "assertions": [
        {
          "field": "document_type",
          "operator": "in",
          "value": ["DRIVERS_LICENSE", "STATE_ID"],
          "required": true
        },
        {
          "field": "issuing_state",
          "operator": "in",
          "value": [
            "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
            "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
            "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
            "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
            "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
            "DC"
          ],
          "required": true
        },
        {
          "field": "document_status",
          "operator": "equals",
          "value": "VALID",
          "required": true
        },
        {
          "field": "expiration_date",
          "operator": "greater_than",
          "value": "current_date",
          "required": true
        },
        {
          "field": "address_state",
          "operator": "in",
          "value": [
            "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
            "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
            "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
            "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
            "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
            "DC"
          ],
          "required": true
        },
        {
          "field": "holder_age",
          "operator": "greater_than_or_equal",
          "value": 16,
          "required": true
        }
      ],
      "selective_disclosure": {
        "revealed_fields": ["address_state"],
        "hidden_fields": [
          "full_name",
          "id_number",
          "date_of_birth",
          "full_address",
          "photograph"
        ]
      }
    },
    {
      "name": "SSN + Address Verification",
      "method": "ssn_address",
      "data_source": {
        "type": "zkTLS",
        "endpoints": [
          {
            "name": "USPS Address Verification",
            "url": "https://tools.usps.com/go/ZipLookupAction"
          },
          {
            "name": "SSN Validation Service",
            "url": "https://ssa.gov/employer/ssnv.htm"
          }
        ],
        "description": "USPS Address Verification API + SSN validation"
      },
      "assertions": [
        {
          "field": "ssn_issued",
          "operator": "equals",
          "value": true,
          "required": true
        },
        {
          "field": "ssn_valid",
          "operator": "equals",
          "value": true,
          "required": true
        },
        {
          "field": "address_deliverable",
          "operator": "equals",
          "value": true,
          "required": true
        },
        {
          "field": "address_country",
          "operator": "equals",
          "value": "USA",
          "required": true
        },
        {
          "field": "address_residential",
          "operator": "equals",
          "value": true,
          "required": true
        }
      ],
      "selective_disclosure": {
        "revealed_fields": ["address_country"],
        "hidden_fields": [
          "full_ssn",
          "full_address",
          "name"
        ]
      }
    },
    {
      "name": "US Bank Account Verification",
      "method": "bank_account",
      "data_source": {
        "type": "API",
        "endpoint": "https://production.plaid.com/auth/get",
        "description": "Plaid Auth API (requires API key)",
        "requires_oauth": true
      },
      "assertions": [
        {
          "field": "account_status",
          "operator": "equals",
          "value": "ACTIVE",
          "required": true
        },
        {
          "field": "account_country",
          "operator": "equals",
          "value": "USA",
          "required": true
        },
        {
          "field": "account_type",
          "operator": "in",
          "value": ["CHECKING", "SAVINGS"],
          "required": true
        },
        {
          "field": "routing_number_country",
          "operator": "equals",
          "value": "USA",
          "required": true
        },
        {
          "field": "account_age_days",
          "operator": "greater_than_or_equal",
          "value": 90,
          "required": true
        }
      ],
      "selective_disclosure": {
        "revealed_fields": [],
        "hidden_fields": [
          "account_number",
          "routing_number",
          "bank_name",
          "account_balance",
          "transaction_history"
        ]
      }
    }
  ],
  "logic": {
    "type": "OR",
    "description": "At least one assertion group must pass",
    "groups": [
      "US Passport Verification",
      "State ID / Driver's License Verification",
      "SSN + Address Verification",
      "US Bank Account Verification"
    ]
  },
  "security_properties": {
    "zero_knowledge": true,
    "non_transferable": true,
    "replay_resistant": true,
    "tamper_proof": true,
    "time_limited": true,
    "device_binding": true
  },
  "output_format": {
    "type": "ZKProof",
    "fields": {
      "proof_type": "string (us_passport | state_id | ssn_address | bank_account)",
      "is_valid": "boolean",
      "verified_at": "ISO 8601 timestamp",
      "expires_at": "ISO 8601 timestamp",
      "confidence_score": "number (0.0 - 1.0)",
      "assertions_passed": "string[]"
    }
  },
  "implementation_notes": {
    "phase_1": "Start with US Passport only for MVP",
    "phase_2": "Add State ID and Bank Account in weeks 4-6",
    "phase_3": "Add SSN verification in weeks 8-12",
    "testing": "Use zkPass sandbox environment with test credentials",
    "devhub_url": "https://dev.zkpass.org/",
    "documentation": "https://docs.zkpass.org/"
  },
  "compliance": {
    "gdpr": {
      "data_minimization": true,
      "privacy_by_design": true,
      "right_to_erasure": true
    },
    "ccpa": {
      "user_control": true,
      "opt_out_mechanism": true
    },
    "eeoc": {
      "non_discriminatory": true,
      "work_auth_only": true
    }
  }
}
